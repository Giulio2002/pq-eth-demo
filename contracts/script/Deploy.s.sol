pragma solidity ^0.8.20;

import "forge-std/Script.sol";
import "../src/PQWalletFactory.sol";
import "../src/USD.sol";
import "../src/JEDKH.sol";

contract Deploy is Script {
    bytes constant FALCON_NTT_BYTECODE = hex"";
    bytes constant DILITHIUM_NTT_BYTECODE = hex"";

    function run() external {
        uint256 deployerKey = vm.envOr("PRIVATE_KEY", uint256(0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80));
        address deployer = vm.addr(deployerKey);

        vm.startBroadcast(deployerKey);

        // 1. Deploy NTT Verifier contracts (Yul bytecode)
        address falconNTT;
        address dilithiumNTT;
        bytes memory falconCode = FALCON_NTT_BYTECODE;
        bytes memory dilithiumCode = DILITHIUM_NTT_BYTECODE;
        assembly {
            falconNTT := create(0, add(falconCode, 0x20), mload(falconCode))
            dilithiumNTT := create(0, add(dilithiumCode, 0x20), mload(dilithiumCode))
        }
        require(falconNTT != address(0), "FalconVerifierNTT deploy failed");
        require(dilithiumNTT != address(0), "DilithiumVerifierNTT deploy failed");

        // 2. Deploy PQWalletFactory (deploys per-algorithm wallets)
        PQWalletFactory factory = new PQWalletFactory();

        // 3. Deploy USD stablecoin
        USD usd = new USD();
        usd.mint(deployer, 500_000 ether);

        // 4. Deploy JEDKH token
        JEDKH jedkh = new JEDKH();
        jedkh.mint(deployer, 500_000 ether);

        vm.stopBroadcast();

        string memory json = string(abi.encodePacked(
            '{\n  "chainId": ', vm.toString(block.chainid),
            ',\n  "PQWalletFactory": "', vm.toString(address(factory)),
            '",\n  "FalconVerifierNTT": "', vm.toString(falconNTT),
            '",\n  "DilithiumVerifierNTT": "', vm.toString(dilithiumNTT),
            '",\n  "USD": "', vm.toString(address(usd)),
            '",\n  "JEDKH": "', vm.toString(address(jedkh)),
            '",\n  "payerAddress": "0x70997970C51812dc3A010C7d01b50e0d17dc79C8"\n}'
        ));
        vm.writeFile("deployments.json", json);
    }
}
